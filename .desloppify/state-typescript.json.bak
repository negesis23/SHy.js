    "review::.::holistic::cross_module_architecture::global_mutable_state_hub": {
      "id": "review::.::holistic::cross_module_architecture::global_mutable_state_hub",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "Shared mutable state in core reactivity module creates high coupling and initialization side effects.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "packages/shy/src/reactivity/core.ts"
        ],
        "evidence": [
          "Global exported variables: currentEffect, errorHandlers, pendingEffects, transitionEffects, microtaskQueued, isTransitioning",
          "Multiple functions (pushErrorHandler, setCurrentEffect, setTransitioning) mutate these globals directly."
        ],
        "suggestion": "Encapsulate reactivity state within a 'Root' or 'Context' object to allow multiple independent reactivity instances and avoid side effects on module import.",
        "reasoning": "",
        "summary_hash": "a143028a"
      },
      "status": "fixed",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-04-08T06:55:53+00:00",
      "last_seen": "2026-04-08T06:55:53+00:00",
      "resolved_at": "2026-04-08T07:18:30+00:00",
      "reopen_count": 0,
      "work_item_kind": "review_defect",
      "issue_kind": "review_defect",
      "origin": "review_import",
      "lang": "typescript",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null,
      "resolution_attestation": {
        "kind": "agent_import",
        "text": "not reported in latest holistic re-import",
        "attested_at": "2026-04-08T07:18:30+00:00",
        "scan_verified": false
      }
    },
    "review::.::holistic::cross_module_architecture::excessive_barrel_exports": {
      "id": "review::.::holistic::cross_module_architecture::excessive_barrel_exports",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "Root and subdirectory barrel files obscure module boundaries and promote tight coupling.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "packages/shy/src/index.ts",
          "packages/shy/src/reactivity/index.ts"
        ],
        "evidence": [
          "index.ts re-exports everything from all subdirectories, including internal implementation details like 'core'.",
          "This pattern encourages consumers to import from the root, making it harder to track dependency flow."
        ],
        "suggestion": "Limit barrel exports to the public API only. Internal modules should import from specific files to prevent circularity and clarify boundaries.",
        "reasoning": "",
        "summary_hash": "b375a2b3"
      },
      "status": "fixed",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-04-08T06:55:53+00:00",
